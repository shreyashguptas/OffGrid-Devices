# Committed, PUBLIC build-time values ONLY.
#
# NEVER put secrets in this file — it is checked into git. Secrets belong in:
#   - local dev:  .env.local  (gitignored)
#   - production: `wrangler secret put <NAME>`
#
# Cloudflare Turnstile SITE key — public by design (it ships to every visitor's
# browser). Read at build time by the contact form's "are you human?" widget.
# The matching SECRET key is set separately via `wrangler secret put TURNSTILE_SECRET_KEY`.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAADaCldOi9gIOKbM-

# PostHog client analytics — these NEXT_PUBLIC_* values are inlined into the
# browser bundle at build time, so they MUST be present wherever the production
# build runs (local AND the CI deploy job). The project token is the public,
# write-only ingest key (phc_*) — safe to commit. The server-side ingest host
# (POSTHOG_PROJECT_HOST) and any tokens stay out of this file.
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=phc_AXfaoqJ8czPwrecHrKPuQ65gobFzm3EwxfrEgWYpn4rD
NEXT_PUBLIC_POSTHOG_HOST=/ingest
NEXT_PUBLIC_POSTHOG_UI_HOST=https://us.posthog.com
